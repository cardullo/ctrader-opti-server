# ── Authentication ──────────────────────────────────────────────────────
API_KEY=changeme-to-a-strong-secret

# ── Data directory (inside the container) ──────────────────────────────
DATA_DIR=/data

# ── cTrader credentials ────────────────────────────────────────────────
# Your cTrader ID (email)
CTID=your_ctid@example.com

# Path to the password file on the server filesystem
# This file should contain your cTrader password, never transmitted over API
PWD_FILE_PATH=/data/pwd

# Optional: host-side paths for sibling ctrader-cli containers when the
# server itself runs in Docker.
HOST_DATA_DIR=/home/opti/ctrader-opti-server/data
HOST_PWD_FILE_PATH=/home/opti/ctrader-opti-server/data/pwd

# Default cTrader account number
CTRADER_ACCOUNT=12345678

# ── Concurrency limits ─────────────────────────────────────────────────
# Maximum number of jobs processing simultaneously
MAX_PARALLEL_JOBS=2

# Maximum Docker containers per job
MAX_PARALLEL_WORKERS_PER_JOB=4

# ── Docker image ───────────────────────────────────────────────────────
DOCKER_IMAGE=ghcr.io/spotware/ctrader-console:latest

# ── Timeout per backtest pass (seconds) ────────────────────────────────
PASS_TIMEOUT_SECONDS=600
